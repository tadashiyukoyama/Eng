# ============================================
# Klaus OS — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# --- Banco de Dados ---
DATABASE_URL=mysql://user:password@host:4000/database?ssl={"rejectUnauthorized":true}

# --- Autenticação OAuth Manus ---
JWT_SECRET=sua-chave-secreta-jwt-aqui
VITE_APP_ID=seu-app-id-manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# --- Dono do Projeto ---
OWNER_OPEN_ID=seu-open-id-aqui
OWNER_NAME=Seu Nome

# --- API Forge (LLM, Storage, etc.) ---
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=sk-sua-chave-forge-aqui
VITE_FRONTEND_FORGE_API_KEY=vk-sua-chave-frontend-aqui
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im

# --- App Config ---
VITE_APP_TITLE=Klaus OS
VITE_APP_LOGO=

# --- Analytics (opcional) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
